# === Bot settings (read by the bot at startup) ===

# Telegram
BOT_TOKEN=
ADMIN_CHAT_ID=

# Language (en, ru, es, hi, pt, vi, id)
BOT_LANG=en

# Database
SQLITE_PATH=data/bot.db

# OpenAI (optional — without API key, AI validation is disabled)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Defaults (can be overridden per-chat via /config)
DEFAULT_TIMEOUT_MINUTES=30
DEFAULT_MIN_RESPONSE_LENGTH=50
DEFAULT_AI_VALIDATION=true
DEFAULT_BAN_ON_REMOVE=false
